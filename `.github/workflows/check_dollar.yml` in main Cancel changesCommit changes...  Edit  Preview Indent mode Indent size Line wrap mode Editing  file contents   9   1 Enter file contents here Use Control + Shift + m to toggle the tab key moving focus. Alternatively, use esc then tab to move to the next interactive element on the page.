name: Check Dollar Price

on:
  schedule:
    # هر 5 دقیقه یک‌بار اجرا می‌شود
    - cron: '*/5 * * * *'
  workflow_dispatch: # اجرای دستی

jobs:
  check-price:
    runs-on: ubuntu-latest
    
    steps:
    - name: Checkout code
      uses: actions/checkout@v4
      
    - name: Set up Python
      uses: actions/setup-python@v5
      with:
        python-version: '3.11'
        
    - name: Install dependencies
      run: |
        pip install -r requirements.txt
        
    - name: Download last price file
      uses: actions/download-artifact@v4
      with:
        name: last-price
        path: .
      continue-on-error: true
        
    - name: Check dollar price
      env:
        TELEGRAM_BOT_TOKEN: ${{ secrets.TELEGRAM_BOT_TOKEN }}
      run: |
        python check_price.py
        
    - name: Upload last price file
      uses: actions/upload-artifact@v4
      with:
        name: last-price
        path: last_price.txt
        retention-days: 1
